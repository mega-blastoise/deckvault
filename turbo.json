{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist", "out", "build"],
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^build", "^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": ["^start"]
    },
    "test": {
      "dependsOn": ["^build", "^test"]
    },
    "docker:web:start": {
      "dependsOn": ["^docker:web:start"]
    },
    "docker:scripts:db:sync": {
      "dependsOn": ["^docker:scripts:db:sync"],
      "cache": false
    },
    "scripts:json:ls": {
      "dependsOn": ["^scripts:json:ls"],
      "cache": false
    },
    "scripts:json:sync": {
      "dependsOn": ["^scripts:json:sync"],
      "cache": false
    },
    "docs:build": {
      "inputs": ["docs/**", "dxdocs.config.ts"],
      "outputs": ["site/**"]
    },
    "docs:dev": {
      "cache": false,
      "persistent": true
    },
    "pack:cli-shim": {
      "outputs": ["dist-packages/cli/**", "!dist-packages/cli/node_modules/**"]
    },
    "compile": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "build/**", "tsconfig.json"],
      "outputs": ["../../dist-packages/cli-platforms/*/bin/**"]
    },
    "pack:cli-platform": {
      "dependsOn": ["@pokemon/deck-cli#compile"],
      "outputs": ["dist-packages/cli-platforms/**"]
    },
    "pack:mcp-platform": {
      "dependsOn": [],
      "outputs": ["dist-packages/mcp-server-platforms/**"]
    },
    "pack:card-data": {
      "outputs": ["dist-packages/card-data/data/*.db"]
    }
  }
}
