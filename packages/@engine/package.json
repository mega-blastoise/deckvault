{
  "name": "@pokemon/engine",
  "version": "0.0.1-alpha.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./out/lib/index.js",
      "types": "./out/lib/index.d.ts",
      "default": "./out/lib/index.js"
    },
    "./browser": {
      "import": "./out/lib/browser.js",
      "types": "./out/lib/browser.d.ts",
      "default": "./out/lib/browser.js"
    },
    "./types": {
      "import": "./out/lib/types/index.js",
      "types": "./out/lib/types/index.d.ts",
      "default": "./out/lib/types/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build-types": "tsc -p tsconfig.json",
    "bundle": "bun run build.ts",
    "build": "run-s bundle build-types",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "clean": "rm -rf out"
  },
  "devDependencies": {
    "@pokemon/build": "workspace:*",
    "@pokemon/configs": "workspace:*",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.5"
  },
  "engines": {
    "bun": "1.3.5"
  },
  "packageManager": "bun@1.3.5"
}
