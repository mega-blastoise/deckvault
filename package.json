{
  "name": "@pokemon/root",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "docsites/*",
    "dist-packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "check-types": "turbo check-types",
    "clean": "turbo clean",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,js,jsx}\"",
    "start": "turbo start",
    "test": "turbo test",
    "json:sync": "turbo scripts:json:sync",
    "docker:web:start": "turbo run docker:web:start",
    "docker:scripts:db:sync": "turbo run docker:scripts:db:sync",
    "db:report": "bun run scripts/db-card-report.ts",
    "db:missing": "bun run scripts/db-missing-cards.ts",
    "db:export": "bun run scripts/db-export-report.ts",
    "db:replicate": "bun run scripts/db-replicate.ts",
    "db:replicate:force": "SQLITE_REPLICATE_OVERWRITE_DATABASES=1 bun run scripts/db-replicate.ts",
    "docs:build": "turbo docs:build",
    "docs:dev": "turbo docs:dev",
    "db:dev": "docker compose --project-name pokemon-dev -f docker-compose.dev.yml up -d",
    "db:dev:stop": "docker compose --project-name pokemon-dev -f docker-compose.dev.yml down",
    "db:dev:reset": "docker compose --project-name pokemon-dev -f docker-compose.dev.yml down -v && docker compose --project-name pokemon-dev -f docker-compose.dev.yml up -d",
    "db:dev:logs": "docker logs pokemon-postgres-dev -f --tail=50",
    "db:dev:psql": "docker exec -it pokemon-postgres-dev psql -U pokemon -d pokemon_tcg",
    "deploy:build": "run-p deploy:build:*",
    "deploy:build:web": "docker build -f apps/web/Dockerfile -t ghcr.io/mega-blastoise/deckvault-web:latest .",
    "deploy:build:api": "docker build -f apps/rest-api/Dockerfile -t ghcr.io/mega-blastoise/deckvault-rest-api:latest .",
    "deploy:build:graphql": "docker build -f apps/graphql-api/Dockerfile -t ghcr.io/mega-blastoise/deckvault-graphql-api:latest .",
    "changes:add": "bun scripts/changes.ts add",
    "changes:list": "bun scripts/changes.ts list",
    "changes:release": "bun scripts/changes.ts release",
    "pack:all": "turbo run pack:cli-shim pack:cli-platform pack:mcp-platform pack:card-data"
  },
  "engines": {
    "bun": "1.3.5"
  },
  "packageManager": "bun@1.3.5",
  "dependencies": {
    "debug": "^4.4.3",
    "dotenv": "^17.2.3",
    "supports-color": "^10.2.2",
    "undici": "^7.16.0"
  },
  "peerDependencies": {
    "typescript": "5.5.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/bun": "latest",
    "@types/debug": "^4.1.12",
    "@types/node": "^25.0.3",
    "bun-types": "^1.3.5",
    "eslint": "^9.15.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.2.5",
    "turbo": "^2.3.0",
    "typescript-eslint": "^8.15.0"
  }
}
