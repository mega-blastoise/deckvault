# ============================================================
# rest-api — Local Development Environment
# ============================================================
# Copy this file to .env and fill in the values.
# .env is gitignored and never committed.
#
# Dev postgres runs via: bun run db:dev (from repo root)
# That starts pokemon-postgres-dev on localhost:5433.
# ============================================================

# Server
REST_API_PORT=3001
REST_API_HOST=0.0.0.0

# SQLite — card data (read-only) and deck scratch db
DATABASE_PATH=../../database/pokemon-data.sqlite3.db
DATABASE_READONLY=true
DECK_DATABASE_PATH=../../database/decks.sqlite3.db

# Postgres — dev DB on port 5433 (prod is on internal 5432, never exposed to host)
POSTGRES_URL=postgresql://username:password@postgres_host:5433/database_name
# Auth — Google OAuth
# Get these from https://console.cloud.google.com → Credentials
# Add http://localhost:3001/auth/callback as an Authorized redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/callback

# JWT — any long random string for local dev
# Generate: openssl rand -hex 32
JWT_SECRET=

# CORS — web dev server
CORS_ORIGINS=http://localhost:3000

RESEND_API_KEY=

# Rate limiting (relax for local dev)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=500

# Logging
LOG_LEVEL=debug
LOG_FORMAT=pretty
